#[tauri::command]
pub async fn list_ollama_models() -> Result<Vec<String>, String> {
    let client = Client::new();
    let resp = client
        .get(format!("{OLLAMA_BASE_URL}/api/tags"))
        .timeout(std::time::Duration::from_secs(3))
        .send()
