import { toast } from 'sonner';
import { Drawer } from '../common';
import { PipelineConfig } from '../pipeline/PipelineConfig';
import type { ConfigSection } from '../pipeline/PipelineConfig';
import { useUiStore } from '../../stores/uiStore';
