  fileName: string;
  text: string;
  useChunking: boolean;
  targetChunkCount: number;
  onUseChunkingChange: (value: boolean) => void;
  onTargetChunkCountChange: (value: number) => void;
  onCancel: () => void;
  onConfirm: () => void;
}

