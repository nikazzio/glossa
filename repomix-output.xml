  onConfirm: (name: string) => Promise<void> | void;
  saving?: boolean;
}

export function SaveProjectDialog({
  open,
  onClose,
  onConfirm,
  saving = false,
}: SaveProjectDialogProps) {
  const { t } = useTranslation();
  const [name, setName] = useState('');
  const trapRef = useFocusTrap(open, onClose);

  useEffect(() => {
    if (!open) {
      setName('');
